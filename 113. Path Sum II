class Solution {
public:
    void solve(TreeNode* root, int k, int ssf, vector<int> s_ans, vector<vector<int>>& ans){
        if(root == nullptr) return;
        if(root->left == nullptr && root->right == nullptr){
            s_ans.push_back(root->val);
            ssf += root->val;
            if(ssf == k)
                ans.push_back(s_ans);
            return;
        }
        s_ans.push_back(root->val);
        solve(root->left, k, ssf+root->val, s_ans, ans);
        solve(root->right, k, ssf+root->val, s_ans, ans);
    }
    vector<vector<int>> pathSum(TreeNode* root, int k) {
        vector<vector<int>> ans;
        vector<int> s_ans;
        solve(root, k, 0, s_ans, ans);
        return ans;
    }
};
